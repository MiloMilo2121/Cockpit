# Core
TZ=Europe/Rome
LETSENCRYPT_EMAIL=you@example.com

# Public domains managed by Caddy
DOMAIN_API=api.example.com
DOMAIN_APP=app.example.com
DOMAIN_EVOLUTION=wa.example.com

# PostgreSQL
POSTGRES_DB=lifecockpit
POSTGRES_USER=lifecockpit
POSTGRES_PASSWORD=change-this-postgres-password

# Redis
REDIS_PASSWORD=change-this-redis-password

# cockpit-core (code-first orchestrator)
APP_ENV=production
COCKPIT_WORKER_CONCURRENCY=4
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FREE_MODELS=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_TIMEOUT_SECONDS=45
OPENROUTER_TEMPERATURE=0.2
OPENROUTER_MAX_TOKENS=700

# Google multi-account (Step 7)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=
GOOGLE_OAUTH_SCOPES=openid,email,profile,https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/drive.readonly,https://www.googleapis.com/auth/calendar.readonly
GOOGLE_SYNC_HTTP_TIMEOUT_SECONDS=45
GOOGLE_GMAIL_BOOTSTRAP_MAX_RESULTS=100
GOOGLE_GMAIL_HISTORY_PAGE_SIZE=100
GOOGLE_DRIVE_BOOTSTRAP_PAGE_SIZE=50
GOOGLE_DRIVE_DOWNLOAD_MAX_BYTES=1500000
GOOGLE_CALENDAR_BOOTSTRAP_PAST_DAYS=90
GOOGLE_CALENDAR_BOOTSTRAP_FUTURE_DAYS=180
GOOGLE_CALENDAR_BOOTSTRAP_PAGE_SIZE=250

OLLAMA_MODEL=llama3.2
SMART_BUFFERING_ENABLED=true
SMART_BUFFER_SECONDS=12
SMART_BUFFER_TTL_SECONDS=120
LOOP_BLOCK_FROM_ME=true
ALLOW_LOCAL_DEGRADED_MODE=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=4
CIRCUIT_BREAKER_OPEN_SECONDS=90
DEAD_LETTER_ENABLED=true
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_TTL_SECONDS=300
DEAD_LETTER_ANOMALY_WINDOW_MINUTES=15
DEAD_LETTER_ANOMALY_THRESHOLD=3
DEAD_LETTER_ALERT_COOLDOWN_SECONDS=900
PROACTIVE_DEFAULT_USER_ID=marco
PROACTIVE_NOTIFY_WHATSAPP_ENABLED=true

# File watcher (Step 6)
FILE_WATCHER_SOURCE=file_watchdog
FILE_WATCHER_USER_ID=watchdog
FILE_WATCHER_CHUNKING_STRATEGY=semantic
FILE_WATCHER_SETTLE_SECONDS=2
FILE_WATCHER_POLL_INTERVAL_SECONDS=1
FILE_WATCHER_MAX_FILE_BYTES=2500000
FILE_WATCHER_MAX_CONTENT_CHARS=400000
FILE_WATCHER_ALLOWED_EXTENSIONS=txt,md,markdown,csv,json,log,yaml,yml,xml,html,htm,py,js,ts,tsx,jsx,sql,sh,env,ini,toml
FILE_WATCHER_ENABLE_TASK_WEBHOOK=true

# RAG
RAG_COLLECTION_NAME=life_cockpit_memory
RAG_VECTOR_SIZE=384
RAG_CHUNK_SIZE_CHARS=1100
RAG_CHUNK_OVERLAP_CHARS=180
RAG_SEMANTIC_SIMILARITY_THRESHOLD=0.72
RAG_DEFAULT_TOP_K=6
RAG_DENSE_WEIGHT=0.7
RAG_SPARSE_WEIGHT=0.3
RAG_AGENTIC_CHUNK_MAX_CHARS=16000
RAG_QUERY_CANDIDATES=24
RAG_RERANK_CANDIDATES=12

# Qdrant
QDRANT_API_KEY=change-this-qdrant-key

# Evolution API
EVOLUTION_API_KEY=change-this-evolution-api-key
EVOLUTION_INSTANCE=life-cockpit
PROACTIVE_WHATSAPP_NUMBER=393331112223

# Local privacy node
CACHE_TTL_SECONDS=600
PRIVACY_SALT=replace-with-random-salt
